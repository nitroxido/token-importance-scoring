# Token Importance — Environment Variables Template
# Copy this file to .env and fill in the values you need.
# .env is in .gitignore and must never be committed.
#
# These values are optional locally (you can also use `fal auth login` and
# `huggingface-cli login` for interactive auth). They are needed for non-interactive
# environments (CI, scripts) and are set as fal secrets for remote jobs.

# -------------------------------------------------------------------
# GitHub Personal Access Token (Classic)
# Required: for pip-installing the private repo on fal.ai remote machines.
# Scope needed: repo (read)
# Generate at: https://github.com/settings/tokens
# Set as fal secret with: fal secrets set GITHUB_TOKEN <value>
# -------------------------------------------------------------------
GITHUB_TOKEN=

# -------------------------------------------------------------------
# HuggingFace Access Token
# Required only for gated models (e.g. LLaMA-3.1-8B-Instruct).
# Mistral-7B-v0.3 does NOT require this.
# Generate at: https://huggingface.co/settings/tokens
# Set as fal secret with: fal secrets set HF_TOKEN <value>
# -------------------------------------------------------------------
HF_TOKEN=

# -------------------------------------------------------------------
# fal.ai API Key
# Alternative to `fal auth login` for non-interactive environments.
# Generate at: https://fal.ai/dashboard/keys
# -------------------------------------------------------------------
FAL_KEY=
